{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "build",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "isolatedModules": true,
    "lib": ["ES2020"],
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,

    "sourceMap": true,
  }
}